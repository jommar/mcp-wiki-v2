# Transport — stdio (local) or http (remote)
# TRANSPORT=stdio
# PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=wiki
DB_PASSWORD=wiki
DB_NAME=wiki

# Wiki source paths (for import script)
WIKI_SOURCES=/ai/wiki,/home/dev/transAct/docs

# Default wiki ID (optional — if set, wikiId is omitted from all tool schemas)
# WIKI_ID=user-wiki

# ── HTTP transport security ──────────────────────────────────────────────────
# Enable when running behind a reverse proxy (nginx, Caddy) so the real client
# IP is read from X-Forwarded-For for rate limiting. Leave unset otherwise —
# the header is trivially spoofable without a trusted proxy in front.
# TRUST_PROXY=true

# ── Auth cache tuning ────────────────────────────────────────────────────────
# How long a successful token verification is cached (ms). Lower = faster key
# revocation propagation; higher = fewer bcrypt round-trips under load.
# AUTH_CACHE_TTL_MS=300000

# How long a failed token attempt is cached to skip repeated bcrypt loops (ms).
# AUTH_FAILED_CACHE_TTL_MS=60000

# ── Linking & search tuning ──────────────────────────────────────────────────
# Max outgoing links inserted per section during auto-linking.
# MAX_LINKS_PER_SECTION=4

# Minimum cosine similarity score to prefer semantic results over keyword search.
# SIMILARITY_THRESHOLD=0.1

# Minimum time (ms) between read-triggered relink attempts for the same section.
# RELINK_DEBOUNCE_MS=300000

# Max parallel DB connections used during auto_link_sections background job.
# AUTO_LINK_CONCURRENCY=10

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
LOG_RETENTION_DAYS=10

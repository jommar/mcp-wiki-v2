{
  "name": "wiki-explorer-v2",
  "version": "2.0.0",
  "description": "MCP server for wiki management backed by PostgreSQL",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "import": "node scripts/import-wiki-to-db.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "node test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "fix": "npm run lint:fix && npm run format",
    "init": "cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "keywords": [
    "mcp",
    "wiki",
    "postgresql",
    "pgvector"
  ],
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.0",
    "marked": "^17.0.5",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3"
  }
}
